{
  "name": "@sayagodev/beidou",
  "version": "1.0.0",
  "description": "Keyboard navigation overlay — press Alt to see shortcuts, press a letter to click. Zero config, tiny footprint.",
  "author": "sayago;dev",
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "unpkg": "dist/index.min.cjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "keyboard",
    "navigation",
    "shortcuts",
    "accessibility",
    "alt",
    "hotkeys"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sayagodev/beidou"
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "npx tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
